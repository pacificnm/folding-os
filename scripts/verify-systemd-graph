class VerificationError(Exception):
    """A systemd graph verification failure."""


def fail(message):
    raise VerificationError(message)


def normalize(name):
    return name.removeprefix("./").rstrip("/")


def parse_unit(text):
    values = defaultdict(set)
    section = None
    for raw_line in text.splitlines():
        line = raw_line.strip()
        if not line or line.startswith(("#", ";")):
            continue
        if line.startswith("[") and line.endswith("]"):
            section = line[1:-1]
            continue
        if section and "=" in line:
            key, value = line.split("=", 1)
            if value:
                values[(section, key)].update(value.split())
    return values


def add_ordering_edges(graph, unit_name, values):
    for dependency in values.get(("Unit", "After"), set()):
        graph[dependency].add(unit_name)
    for dependency in values.get(("Unit", "Before"), set()):
        graph[unit_name].add(dependency)


def find_cycle(graph):
    active = set()
    visited = set()

    def visit(node, path):
        if node in active:
            return path[path.index(node) :] + [node]
        if node in visited:
            return None
        active.add(node)
        for successor in graph[node]:
            cycle = visit(successor, path + [successor])
            if cycle:
                return cycle
        active.remove(node)
        visited.add(node)
        return None

    for node in tuple(graph):
        cycle = visit(node, [node])
        if cycle:
            return cycle
    return None


def main():
    if len(sys.argv) > 2:
        print("Usage: ./scripts/verify-systemd-graph [rootfs.tar]", file=sys.stderr)
        return 2

    rootfs_path = Path(sys.argv[1]) if len(sys.argv) == 2 else DEFAULT_ROOTFS
    if not rootfs_path.is_file():
        fail(f"root filesystem archive does not exist: {rootfs_path}")

    with tarfile.open(rootfs_path) as archive:
        members = {normalize(member.name): member for member in archive.getmembers()}

        for unit in FOUNDATION_UNITS:
            if f"usr/lib/systemd/system/{unit}" not in members:
                fail(f"required foundation unit is absent: {unit}")

        for unit in FAH_RUNTIME_UNITS:
            if f"usr/lib/systemd/system/{unit}" not in members:
                fail(f"required FAH runtime unit is absent: {unit}")

        for unit in FOLDOPS_RUNTIME_UNITS:
            if f"usr/lib/systemd/system/{unit}" not in members:
                fail(f"required FoldOps runtime unit is absent: {unit}")

        forbidden = []
        for name in members:
            normalized = normalize(name)
            if "/systemd/system/" not in normalized:
                continue
            unit_name = Path(normalized).name
            if "foldops" not in unit_name.lower():
                continue
            if unit_name not in APPROVED_FOLDOPS_UNIT_NAMES:
                forbidden.append(normalized)
        if forbidden:
            fail(f"premature or undocumented FoldOps runtime unit is present: {forbidden[0]}")

        project_enabled = {
            name
            for name, member in members.items()
            if member.issym()
            and "/systemd/system/" in name
            and (
                Path(name).name.startswith("foldingos-")
                or Path(name).name == "folding-at-home.service"
            )
        }
        expected_project_enabled = {
            link
            for link in REQUIRED_LINKS
            if Path(link).name.startswith("foldingos-")
            or Path(link).name == "folding-at-home.service"
        }
        if project_enabled != expected_project_enabled:
            fail(
                "enabled FoldingOS units differ from the approved foundation set: "
                f"expected {sorted(expected_project_enabled)}, found {sorted(project_enabled)}"
            )

        for link, target in REQUIRED_LINKS.items():
            member = members.get(link)
            if member is None or not member.issym():
                fail(f"required enabled-unit link is absent: {link}")
            if member.linkname != target:
                fail(
                    f"enabled-unit link has wrong target: {link} -> "
                    f"{member.linkname}, expected {target}"
                )

        graph = defaultdict(set)
        for unit_name, requirements in UNIT_REQUIREMENTS.items():
            if ".d/" in unit_name:
                path = f"etc/systemd/system/{unit_name}"
            else:
                path = f"usr/lib/systemd/system/{unit_name}"
            member = members.get(path)
            if member is None:
                fail(f"required unit configuration is absent: {path}")
            source = archive.extractfile(member)
            if source is None:
                fail(f"cannot read unit configuration: {path}")
            values = parse_unit(source.read().decode("utf-8"))
            for key, expected in requirements.items():
                if not expected.issubset(values.get(key, set())):
                    fail(
                        f"{unit_name} is missing {key[0]}.{key[1]} values: "
                        f"{sorted(expected - values.get(key, set()))}"
                    )
            forbidden_requires = FAILURE_ISOLATION_FORBIDDEN_REQUIRES.get(
                unit_name, set()
            )
            unexpected = values.get(("Unit", "Requires"), set()) & forbidden_requires
            if unexpected:
                fail(
                    f"{unit_name} violates failure isolation with Requires=: "
                    f"{sorted(unexpected)}"
                )
            add_ordering_edges(graph, unit_name.split(".d/", 1)[0], values)

        cycle = find_cycle(graph)
        if cycle:
            fail(f"foundation unit ordering cycle found: {' -> '.join(cycle)}")

    print("FoldingOS foundation systemd graph verified.")
    print("Folding@home acquisition, prepare, and runtime units are present.")
    return 0


if __name__ == "__main__":
    try:
        sys.exit(main())
    except (OSError, tarfile.TarError, UnicodeDecodeError, VerificationError) as error:
        print(f"ERROR: {error}", file=sys.stderr)
        sys.exit(1)
