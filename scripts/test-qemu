#!/usr/bin/env bash
set -euo pipefail
export LC_ALL=C

PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
IMAGES_DIR="${PROJECT_ROOT}/build/output/images"
HOST_DIR="${PROJECT_ROOT}/build/output/host"
TEST_DIR="${PROJECT_ROOT}/build/test-qemu"
RELEASE_IMAGE="${1:-${IMAGES_DIR}/foldingos-x86_64-0.1.0.img}"
ROOTFS_TAR="${IMAGES_DIR}/rootfs.tar"
EXACT_IMAGE="${TEST_DIR}/foldingos-x86_64-0.1.0-exact.img"
LARGER_IMAGE="${TEST_DIR}/foldingos-x86_64-0.1.0-larger.img"
EXACT_SERIAL_LOG="${TEST_DIR}/exact-serial.log"
LARGER_SERIAL_LOG="${TEST_DIR}/larger-serial.log"
REPEAT_SERIAL_LOG="${TEST_DIR}/repeat-serial.log"
PROVISION_IMAGE="${TEST_DIR}/foldingos-x86_64-0.1.0-provisioned.img"
PROVISION_SERIAL_LOG="${TEST_DIR}/provisioned-serial.log"
CONFIG_IMAGE="${TEST_DIR}/foldingos-x86_64-0.1.0-config-tests.img"
CONFIG_SERIAL_LOG="${TEST_DIR}/config-tests-serial.log"
JOURNAL_FAILURE_IMAGE="${TEST_DIR}/foldingos-x86_64-0.1.0-journal-failure.img"
JOURNAL_BREAK_SERIAL_LOG="${TEST_DIR}/journal-break-serial.log"
JOURNAL_FAILURE_SERIAL_LOG="${TEST_DIR}/journal-failure-serial.log"
JOURNAL_PRESSURE_IMAGE="${TEST_DIR}/foldingos-x86_64-0.1.0-journal-pressure.img"
JOURNAL_PRESSURE_SERIAL_LOG="${TEST_DIR}/journal-pressure-serial.log"
INVALID_PROVISION_SERIAL_LOG="${TEST_DIR}/invalid-provision-serial.log"
RECOVERY_SERIAL_LOG="${TEST_DIR}/recovery-serial.log"
REPLACEMENT_SERIAL_LOG="${TEST_DIR}/replacement-serial.log"
SSH_DIAGNOSTIC_LOG="${TEST_DIR}/ssh-diagnostic.log"
GUEST_ACCEPTANCE_LOG="${TEST_DIR}/guest-acceptance.log"
PRESERVATION_SERIAL_LOG="${TEST_DIR}/preservation-serial.log"
INVALID_IMAGE="${TEST_DIR}/foldingos-x86_64-0.1.0-invalid-layout.img"
INVALID_SERIAL_LOG="${TEST_DIR}/invalid-layout-serial.log"
SSH_KEY="${TEST_DIR}/foldingos-test-key"
SSH_REPLACEMENT_KEY="${TEST_DIR}/foldingos-test-replacement-key"
SSH_REPLACEMENT_KEY_SECOND="${TEST_DIR}/foldingos-test-replacement-key-second"
SSH_REPLACEMENT_KEYS="${TEST_DIR}/foldingos-test-replacement-authorized_keys"
INVALID_PROVISION_COPY="${TEST_DIR}/invalid-provision-authorized_keys"
SSH_IDENTITY="${SSH_KEY}"
SSH_PORT=2222
PERSISTENCE_MODE=none
EXPECTED_IMAGE_SIZE=4294967296
LARGER_IMAGE_SIZE=6442450944
LARGER_DATA_END=12580863
EXPECTED_KERNEL_COMMAND_LINE="BOOT_IMAGE=/boot/bzImage root=PARTUUID=464f4c44-494e-474f-5352-4f4f54000001 rootwait ro console=tty1 console=ttyS0,115200"
BOOT_TIMEOUT=360
SSH_READY_TIMEOUT=60
ACTIVE_QEMU_WRAPPER_PID=""
ACTIVE_QEMU_PID_FILE=""

stop_active_qemu() {
  local qemu_process_pid

  if [ -n "${ACTIVE_QEMU_PID_FILE}" ] && [ -f "${ACTIVE_QEMU_PID_FILE}" ]; then
    qemu_process_pid="$(cat "${ACTIVE_QEMU_PID_FILE}")"
    kill -TERM "${qemu_process_pid}" 2>/dev/null || true
  fi
  if [ -n "${ACTIVE_QEMU_WRAPPER_PID}" ]; then
    kill -TERM "${ACTIVE_QEMU_WRAPPER_PID}" 2>/dev/null || true
  fi

  ACTIVE_QEMU_WRAPPER_PID=""
  ACTIVE_QEMU_PID_FILE=""
}

trap stop_active_qemu EXIT
trap 'stop_active_qemu; exit 130' INT TERM

find_tool() {
  local name="$1"
  local candidate

  for candidate in \
    "${HOST_DIR}/bin/${name}" \
    "${HOST_DIR}/sbin/${name}" \
    "/usr/sbin/${name}" \
    "/sbin/${name}"
  do
    if [ -x "${candidate}" ]; then
      printf '%s\n' "${candidate}"
      return
    fi
  done

  command -v "${name}" 2>/dev/null || {
    echo "ERROR: Required test tool is unavailable: ${name}" >&2
    exit 1
  }
}

find_ovmf_file() {
  local name="$1"
  local candidate

  for candidate in \
    "/usr/share/OVMF/${name}" \
    "/usr/share/ovmf/${name}" \
    "/usr/share/edk2/ovmf/${name}"
  do
    if [ -f "${candidate}" ]; then
      printf '%s\n' "${candidate}"
      return
    fi
  done

  echo "ERROR: Required OVMF firmware file is unavailable: ${name}" >&2
  exit 1
}

assert_contains() {
  local content="$1"
  local expected="$2"
  local description="$3"

  if ! grep -Fq "${expected}" <<<"${content}"; then
    echo "ERROR: ${description}" >&2
    echo "Expected to find: ${expected}" >&2
    exit 1
  fi
}

verify_filesystem() {
  local image="$1"
  local offset="$2"
  local size="$3"
  local label="$4"
  local uuid="$5"
  local type="$6"
  local output

  output="$("${BLKID}" -p -O "${offset}" -S "${size}" "${image}")"
  assert_contains "${output}" "LABEL=\"${label}\"" "Missing filesystem label ${label}."
  assert_contains "${output}" "UUID=\"${uuid}\"" "Unexpected UUID for ${label}."
  assert_contains "${output}" "TYPE=\"${type}\"" "Unexpected filesystem type for ${label}."
}

boot_image() {
  local description="$1"
  local image="$2"
  local serial_log="$3"
  local ssh_expectation="${4:-none}"
  local vars_file="${serial_log%.log}-OVMF_VARS_4M.fd"
  local qemu_pid_file="${serial_log%.log}.pid"
  local qemu_pid
  local qemu_status
  local seconds
  local ssh_ready=false
  local multi_user_seconds=-1

  cp "${OVMF_VARS}" "${vars_file}"
  rm -f "${serial_log}" "${qemu_pid_file}"
  rm -f "${SSH_DIAGNOSTIC_LOG}" "${GUEST_ACCEPTANCE_LOG}"

  echo "Booting ${description} with QEMU/OVMF"
  set +e
  timeout --signal=TERM --kill-after=10s "${BOOT_TIMEOUT}s" \
    "${QEMU}" \
    -machine q35,accel=tcg \
    -cpu max \
    -smp 2 \
    -m 2048 \
    -drive "if=pflash,format=raw,readonly=on,file=${OVMF_CODE}" \
    -drive "if=pflash,format=raw,file=${vars_file}" \
    -drive "if=virtio,format=raw,file=${image}" \
    -nic "user,model=virtio-net-pci,hostfwd=tcp:127.0.0.1:${SSH_PORT}-:22" \
    -display none \
    -monitor none \
    -serial "file:${serial_log}" \
    -pidfile "${qemu_pid_file}" \
    -no-reboot &
  qemu_pid=$!
  ACTIVE_QEMU_WRAPPER_PID="${qemu_pid}"
  ACTIVE_QEMU_PID_FILE="${qemu_pid_file}"
  set -e

  for ((seconds = 0; seconds < BOOT_TIMEOUT; seconds++)); do
    if [ -f "${serial_log}" ] &&
      grep -Eq 'Reached target .*Multi-User|Reached target Multi-User System' "${serial_log}"
    then
      if [ "${multi_user_seconds}" -lt 0 ]; then
        multi_user_seconds="${seconds}"
      fi
      case "${ssh_expectation}" in
        none)
          if expansion_reached_terminal_state "${serial_log}"; then
            stop_active_qemu
            break
          fi
          ;;
        disabled)
          if expansion_reached_terminal_state "${serial_log}"; then
            if ssh_guest true >/dev/null 2>&1; then
              echo "ERROR: SSH accepted a connection when it should be disabled." >&2
              stop_active_qemu
              exit 1
            fi
            stop_active_qemu
            break
          fi
          ;;
        enabled)
          if grep -Eq \
            'Failed to start .*Expand FoldingOS persistent data partition|Stopped .*Expand FoldingOS persistent data partition' \
            "${serial_log}"
          then
            echo "ERROR: Data expansion failed before provisioned SSH became available." >&2
            echo "Serial log: ${serial_log}" >&2
            stop_active_qemu
            exit 1
          fi
          if ssh_guest true >/dev/null 2>&1; then
            ssh_ready=true
            if ! verify_guest_acceptance; then
              echo "ERROR: Provisioned guest acceptance checks failed." >&2
              if [ -s "${GUEST_ACCEPTANCE_LOG}" ]; then
                echo "Guest acceptance diagnostic: ${GUEST_ACCEPTANCE_LOG}" >&2
                cat "${GUEST_ACCEPTANCE_LOG}" >&2
              fi
              stop_active_qemu
              exit 1
            fi
            stop_active_qemu
            break
          fi
          if [ $((seconds - multi_user_seconds)) -ge "${SSH_READY_TIMEOUT}" ]; then
            ssh_guest true >"${SSH_DIAGNOSTIC_LOG}" 2>&1 || true
            stop_active_qemu
            break
          fi
          ;;
      esac
    fi
    if ! kill -0 "${qemu_pid}" 2>/dev/null; then
      break
    fi
    sleep 1
  done

  set +e
  wait "${qemu_pid}"
  qemu_status=$?
  ACTIVE_QEMU_WRAPPER_PID=""
  ACTIVE_QEMU_PID_FILE=""
  rm -f "${qemu_pid_file}"
  set -e

  if [ "${qemu_status}" -ne 0 ] &&
    [ "${qemu_status}" -ne 124 ] &&
    [ "${qemu_status}" -ne 143 ]
  then
    echo "ERROR: QEMU exited unexpectedly with status ${qemu_status}." >&2
    echo "Serial log: ${serial_log}" >&2
    exit 1
  fi

  if ! grep -Fq "Linux version" "${serial_log}"; then
    echo "ERROR: Linux did not start." >&2
    echo "Serial log: ${serial_log}" >&2
    exit 1
  fi
  if ! grep -Fq "GNU GRUB  version" "${serial_log}"; then
    echo "ERROR: OVMF did not load GRUB." >&2
    echo "Serial log: ${serial_log}" >&2
    exit 1
  fi
  if ! grep -Fq "Command line: ${EXPECTED_KERNEL_COMMAND_LINE}" "${serial_log}"; then
    echo "ERROR: Kernel did not receive the approved command line." >&2
    echo "Expected: ${EXPECTED_KERNEL_COMMAND_LINE}" >&2
    echo "Serial log: ${serial_log}" >&2
    exit 1
  fi

  if ! grep -Eq 'Reached target .*Multi-User|Reached target Multi-User System' "${serial_log}"; then
    echo "ERROR: systemd did not reach the multi-user target." >&2
    echo "Serial log: ${serial_log}" >&2
    exit 1
  fi
  if ! grep -Fq 'FoldingOS 0.1.0 ready' "${serial_log}"; then
    echo "ERROR: Commissioning display did not report ready status." >&2
    echo "Serial log: ${serial_log}" >&2
    exit 1
  fi
  if ! grep -Fq 'SSH: foldingos-admin@' "${serial_log}"; then
    echo "ERROR: Commissioning display did not report SSH entry point." >&2
    echo "Serial log: ${serial_log}" >&2
    exit 1
  fi
  if grep -Fq "Ordering cycle found" "${serial_log}"; then
    echo "ERROR: systemd detected an ordering cycle." >&2
    echo "Serial log: ${serial_log}" >&2
    exit 1
  fi
  if grep -Fq "Unit configuration has fatal error" "${serial_log}"; then
    echo "ERROR: systemd rejected a unit configuration." >&2
    echo "Serial log: ${serial_log}" >&2
    exit 1
  fi
  if grep -Eq 'Finished .*Expand FoldingOS persistent data partition' "${serial_log}"; then
    assert_data_fsck_completed "${serial_log}"
  fi
  if [ "${ssh_expectation}" = disabled ] &&
    grep -Eq 'Started .*OpenSSH server daemon' "${serial_log}"
  then
    echo "ERROR: OpenSSH started when it should be disabled." >&2
    echo "Serial log: ${serial_log}" >&2
    exit 1
  fi
  if [ "${ssh_expectation}" = enabled ] && [ "${ssh_ready}" != true ]; then
    echo "ERROR: Provisioned SSH access did not become available." >&2
    if [ -s "${SSH_DIAGNOSTIC_LOG}" ]; then
      echo "SSH diagnostic: ${SSH_DIAGNOSTIC_LOG}" >&2
      cat "${SSH_DIAGNOSTIC_LOG}" >&2
    fi
    echo "Serial log: ${serial_log}" >&2
    exit 1
  fi
}

ssh_guest() {
  ssh_user foldingos-admin "$@"
}

expansion_reached_terminal_state() {
  local serial_log="$1"

  grep -Eq \
    'Finished .*Expand FoldingOS persistent data partition|Failed to start .*Expand FoldingOS persistent data partition|Stopped .*Expand FoldingOS persistent data partition' \
    "${serial_log}"
}

ssh_user() {
  local user="$1"
  shift
  ssh_user_with_key "${SSH_IDENTITY}" "${user}" "$@"
}

ssh_user_with_key() {
  local identity="$1"
  local user="$2"
  shift 2
  "${SSH}" \
    -F /dev/null \
    -i "${identity}" \
    -p "${SSH_PORT}" \
    -o BatchMode=yes \
    -o ConnectTimeout=2 \
    -o LogLevel=ERROR \
    -o StrictHostKeyChecking=no \
    -o UserKnownHostsFile=/dev/null \
    "${user}@127.0.0.1" "$@"
}

verify_guest_acceptance() {
  if ! ssh_guest '
    set -eux
    test "$(id -u)" = 1000
    sudo -n true
    sudo grep -Fxq "foldingos-admin:NP:::::::" /etc/shadow
    test "$(readlink /etc/os-release)" = ../usr/lib/os-release
    test "$(cat /usr/lib/os-release)" = "NAME=\"FoldingOS\"
ID=foldingos
VERSION=\"0.1.0\"
VERSION_ID=\"0.1.0\"
PRETTY_NAME=\"FoldingOS 0.1.0\""
    findmnt /boot/efi >/dev/null
    findmnt /data >/dev/null
    networkctl status --no-pager enp0s2 >/dev/null
    systemctl is-active --quiet systemd-networkd.service
    systemctl is-active --quiet systemd-resolved.service
    systemctl is-active --quiet systemd-timesyncd.service
    systemctl is-active --quiet foldingos-data-expand.service
    systemctl is-active --quiet foldingos-persistent-dirs.service
    systemctl is-active --quiet foldingos-identity.service
    systemctl is-active --quiet foldingos-config-validate.service
    foldingosctl fah validate-manifest
    systemctl is-active --quiet foldingos-ssh-provision.service
    systemctl is-active --quiet foldingos-boot-status.service
    systemctl is-active --quiet sshd.service
    test "$(sudo find /data/apps/fah -maxdepth 0 -user root -group root -perm 0755 -print)" = /data/apps/fah
    test "$(sudo find /data/config -maxdepth 0 -user root -group root -perm 0755 -print)" = /data/config
    test "$(sudo find /data/config/last-good -maxdepth 0 -user root -group root -perm 0700 -print)" = /data/config/last-good
    test "$(sudo find /data/config/overrides -maxdepth 0 -user root -group root -perm 0755 -print)" = /data/config/overrides
    test "$(sudo find /data/config/secrets -maxdepth 0 -user root -group root -perm 0700 -print)" = /data/config/secrets
    test "$(sudo find /data/fah -maxdepth 0 -user fah -group fah -perm 0750 -print)" = /data/fah
    test "$(sudo find /data/state -maxdepth 0 -user root -group root -perm 0755 -print)" = /data/state
    if [ "'"${PERSISTENCE_MODE}"'" = journal-failure ]; then
      ! systemctl is-active --quiet foldingos-journal-dir.service
      ! systemctl is-active --quiet var-log-journal.mount
      ! systemctl is-active --quiet foldingos-journal-flush.service
    else
      systemctl is-active --quiet foldingos-journal-dir.service
      systemctl is-active --quiet var-log-journal.mount
      systemctl is-active --quiet foldingos-journal-flush.service
      test "$(sudo find /data/logs/journal -maxdepth 0 -user root -group systemd-journal -perm 2755 -print)" = /data/logs/journal
    fi
    attempts=0
    until resolvectl query time.cloudflare.com >/dev/null 2>&1; do
      attempts=$((attempts + 1))
      test "${attempts}" -lt 30
      sleep 1
    done
    sudo sshd -T | grep -Fxq "permitrootlogin no"
    sudo sshd -T | grep -Fxq "passwordauthentication no"
    sudo sshd -T | grep -Fxq "permitemptypasswords no"
    sudo sshd -T | grep -Fxq "kbdinteractiveauthentication no"
    sudo sshd -T | grep -Fxq "pubkeyauthentication yes"
    sudo sshd -T | grep -Fxq "allowusers foldingos-admin"
    attempts=0
    while [ "$(timedatectl show -p NTPSynchronized --value)" != yes ]; do
      attempts=$((attempts + 1))
      test "${attempts}" -lt 180
      sleep 1
    done
    test -s /data/config/node-id
    test -s /data/config/ssh/authorized_keys
    test "$(find /data/config/ssh -maxdepth 0 -user root -group root -perm 0755 -print)" = /data/config/ssh
    test "$(find /data/config/ssh/authorized_keys -maxdepth 0 -user root -group root -perm 0644 -print)" = /data/config/ssh/authorized_keys
    test "$(sudo find /data/config/ssh/host-keys -maxdepth 0 -user root -group root -perm 0700 -print)" = /data/config/ssh/host-keys
    test "$(sudo find /data/config/ssh/host-keys/ssh_host_ed25519_key -maxdepth 0 -user root -group root -perm 0600 -print)" = /data/config/ssh/host-keys/ssh_host_ed25519_key
    test "$(sudo find /data/config/ssh/host-keys/ssh_host_ed25519_key.pub -maxdepth 0 -user root -group root -perm 0644 -print)" = /data/config/ssh/host-keys/ssh_host_ed25519_key.pub
    test ! -e /boot/efi/foldingos/provision/authorized_keys

  ' >"${GUEST_ACCEPTANCE_LOG}" 2>&1; then
    return 1
  fi
  case "${PERSISTENCE_MODE}" in
    config)
      if ! ssh_guest '
        set -eux
        valid=/data/config/foldinghome-test-valid.toml
        malformed=/data/config/foldinghome-test-malformed.toml
        unknown=/data/config/foldinghome-test-unknown.toml
        invalid_gpus=/data/config/foldinghome-test-invalid-gpus.toml
        secret_candidate=/data/config/foldinghome-test-secret.toml
        printf "schema_version = 1\n\n[identity]\nusername = \"Test User\"\nteam = 0\npasskey_secret = \"\"\n\n[resources]\ncpus = 0\ngpus = false\n" | sudo tee "${valid}" >/dev/null
        sudo foldingosctl config activate foldinghome "${valid}"
        sudo foldingosctl config effective foldinghome | grep -Fq "username = \"Test User\""
        printf "schema_version = nope\n" | sudo tee "${malformed}" >/dev/null
        if sudo foldingosctl config activate foldinghome "${malformed}" 2>/dev/null; then
          exit 1
        fi
        printf "schema_version = 1\n\n[identity]\nusername = \"Test User\"\nteam = 0\npasskey_secret = \"\"\nunknown = true\n\n[resources]\ncpus = 0\ngpus = false\n" | sudo tee "${unknown}" >/dev/null
        if sudo foldingosctl config activate foldinghome "${unknown}" 2>/dev/null; then
          exit 1
        fi
        printf "schema_version = 1\n\n[identity]\nusername = \"Broken User\"\nteam = 0\npasskey_secret = \"\"\n\n[resources]\ncpus = 0\ngpus = true\n" | sudo tee "${invalid_gpus}" >/dev/null
        if sudo foldingosctl config activate foldinghome "${invalid_gpus}" 2>/dev/null; then
          exit 1
        fi
        sudo foldingosctl config effective foldinghome | grep -Fq "username = \"Test User\""
        printf "%s\n" top-secret-passkey-value | sudo tee /data/config/secrets/fah-passkey >/dev/null
        sudo chown root:fah /data/config/secrets/fah-passkey
        sudo chmod 640 /data/config/secrets/fah-passkey
        printf "schema_version = 1\n\n[identity]\nusername = \"Test User\"\nteam = 0\npasskey_secret = \"fah-passkey\"\n\n[resources]\ncpus = 0\ngpus = false\n" | sudo tee "${secret_candidate}" >/dev/null
        sudo foldingosctl config activate foldinghome "${secret_candidate}"
        effective="$(sudo foldingosctl config effective foldinghome)"
        printf "%s\n" "${effective}" | grep -Fq "passkey_secret = \"fah-passkey\""
        if printf "%s\n" "${effective}" | grep -Fq top-secret-passkey-value; then
          exit 1
        fi
        sudo cp "${malformed}" /data/config/foldinghome.toml
        sudo foldingosctl config validate --all 2>/dev/null
        sudo foldingosctl config effective foldinghome 2>/dev/null | grep -Fq "username = \"Test User\""
        sudo rm -f /data/config/last-good/foldinghome.toml
        sudo foldingosctl config validate --all 2>/dev/null
        sudo foldingosctl config effective foldinghome 2>/dev/null | grep -Fq "username = \"Anonymous\""
        systemctl is-active --quiet sshd.service
        systemctl is-active --quiet systemd-networkd.service
      ' >"${GUEST_ACCEPTANCE_LOG}" 2>&1; then
        return 1
      fi
      ;;
    create)
      if ! ssh_guest '
        set -eux
        sudo cp /data/config/node-id /data/state/node-id-test
        printf "%s\n" foldingos-storage-preserved | sudo tee /data/state/storage-preservation-test >/dev/null
        printf "%s\n" foldingos-journal-preserved | sudo systemd-cat -t foldingos-journal-test
        sudo journalctl --flush
        sudo ssh-keygen -lf /data/config/ssh/host-keys/ssh_host_ed25519_key |
          sudo tee /data/state/ssh-host-key-fingerprint >/dev/null
        sudo sync
      ' >"${GUEST_ACCEPTANCE_LOG}" 2>&1; then
        return 1
      fi
      ;;
    check|replacement)
      if ! ssh_guest '
        set -eux
        test "$(cat /data/config/node-id)" = "$(cat /data/state/node-id-test)"
        grep -Fxq foldingos-storage-preserved /data/state/storage-preservation-test
        sudo journalctl -t foldingos-journal-test --no-pager |
          grep -Fq foldingos-journal-preserved
        test "$(sudo ssh-keygen -lf /data/config/ssh/host-keys/ssh_host_ed25519_key)" = \
          "$(cat /data/state/ssh-host-key-fingerprint)"
        sudo foldingosctl config validate --all >/dev/null
        sudo foldingosctl config effective foldinghome | grep -Fq "username = \"Anonymous\""
      ' >"${GUEST_ACCEPTANCE_LOG}" 2>&1; then
        return 1
      fi
      ;;
    journal-break)
      if ! ssh_guest '
        set -eux
        sudo systemctl stop foldingos-journal-flush.service
        sudo systemctl stop systemd-journald.service systemd-journald.socket
        sudo umount /var/log/journal
        sudo rm -rf /data/logs/journal
        sudo sh -c ": > /data/logs/journal"
        sudo sync
      ' >"${GUEST_ACCEPTANCE_LOG}" 2>&1; then
        return 1
      fi
      ;;
    journal-failure)
      if ! ssh_guest '
        set -eux
        systemctl is-active --quiet multi-user.target
        systemctl is-active --quiet foldingos-persistent-dirs.service
        systemctl is-active --quiet foldingos-identity.service
        systemctl is-active --quiet foldingos-config-validate.service
        systemctl is-active --quiet foldingos-ssh-provision.service
        systemctl is-active --quiet sshd.service
        test -f /data/logs/journal
      ' >"${GUEST_ACCEPTANCE_LOG}" 2>&1; then
        return 1
      fi
      ;;
    journal-pressure)
      if ! ssh_guest '
        set -eux
        sudo fallocate -l 1200M /data/state/journal-pressure-test
        i=0
        while [ "${i}" -lt 2000 ]; do
          logger -t foldingos-journal-pressure "bounded journal pressure ${i}"
          i=$((i + 1))
        done
        sudo sync
        systemctl is-active --quiet multi-user.target
        systemctl is-active --quiet sshd.service
        test -f /data/state/journal-pressure-test
        sudo rm -f /data/state/journal-pressure-test
      ' >"${GUEST_ACCEPTANCE_LOG}" 2>&1; then
        return 1
      fi
      ;;
  esac
  if ssh_user root true >/dev/null 2>&1; then
    echo "ERROR: Root SSH login was accepted." >&2
    return 1
  fi
  if "${SSH}" \
    -F /dev/null \
    -p "${SSH_PORT}" \
    -o BatchMode=yes \
    -o ConnectTimeout=2 \
    -o PreferredAuthentications=password \
    -o PubkeyAuthentication=no \
    -o StrictHostKeyChecking=no \
    -o UserKnownHostsFile=/dev/null \
    foldingos-admin@127.0.0.1 true >/dev/null 2>&1
  then
    echo "ERROR: Password SSH login was accepted." >&2
    return 1
  fi
  if [ "${PERSISTENCE_MODE}" = replacement ]; then
    if ! ssh_user_with_key "${SSH_REPLACEMENT_KEY_SECOND}" foldingos-admin true >/dev/null 2>&1; then
      echo "ERROR: Second replacement SSH key was not accepted." >&2
      return 1
    fi
    if ssh_user_with_key "${SSH_KEY}" foldingos-admin true >/dev/null 2>&1; then
      echo "ERROR: Replaced SSH key remained authorized." >&2
      return 1
    fi
    if [ "$(ssh_guest 'cat /data/config/ssh/authorized_keys')" != "$(cat "${SSH_REPLACEMENT_KEYS}")" ]; then
      echo "ERROR: Active SSH keys do not exactly match the complete replacement set." >&2
      return 1
    fi
  fi
}

assert_data_fsck_completed() {
  local serial_log="$1"
  local fsck_finished_line
  local forced_fsck_finished_line
  local resized_line
  local expansion_finished_line

  if grep -Fq 'File System Check on /dev/disk/by-label/FOLDINGOS_DATA' "${serial_log}"; then
    echo "ERROR: systemd generated a competing data-filesystem check unit." >&2
    echo "Serial log: ${serial_log}" >&2
    exit 1
  fi

  fsck_finished_line="$(grep -n -m1 -F \
    'Checked /dev/vda3 before data mount.' "${serial_log}" | cut -d: -f1 || true)"
  expansion_finished_line="$(grep -n -m1 -E \
    'Finished .*Expand FoldingOS persistent data partition' \
    "${serial_log}" | cut -d: -f1 || true)"

  if [ -z "${fsck_finished_line}" ] || [ -z "${expansion_finished_line}" ] ||
    [ "${fsck_finished_line}" -ge "${expansion_finished_line}" ]
  then
    echo "ERROR: Data filesystem check did not complete before expansion." >&2
    echo "Serial log: ${serial_log}" >&2
    exit 1
  fi

  if grep -Fq 'Expanded /dev/vda3 to sector' "${serial_log}"; then
    forced_fsck_finished_line="$(grep -n -m1 -F \
      'Force-checked /dev/vda3 before data expansion.' "${serial_log}" | cut -d: -f1 || true)"
    resized_line="$(grep -n -m1 -F \
      'Expanded /dev/vda3 to sector' "${serial_log}" | cut -d: -f1 || true)"
    if [ -z "${forced_fsck_finished_line}" ] ||
      [ -z "${resized_line}" ] ||
      [ "${forced_fsck_finished_line}" -ge "${resized_line}" ]
    then
      echo "ERROR: Forced data filesystem check did not complete before resize." >&2
      echo "Serial log: ${serial_log}" >&2
      exit 1
    fi
  fi
}

assert_expansion_service_succeeded() {
  local serial_log="$1"

  if grep -Eq 'Failed to start .*Expand FoldingOS persistent data partition' "${serial_log}"; then
    echo "ERROR: Data expansion service failed." >&2
    echo "Serial log: ${serial_log}" >&2
    exit 1
  fi
  if grep -Eq 'Stopped .*Expand FoldingOS persistent data partition' "${serial_log}"; then
    echo "ERROR: Data expansion service stopped before completion." >&2
    echo "Serial log: ${serial_log}" >&2
    exit 1
  fi
  if ! grep -Eq 'Finished .*Expand FoldingOS persistent data partition' "${serial_log}"; then
    echo "ERROR: Data expansion service did not finish successfully." >&2
    echo "Serial log: ${serial_log}" >&2
    exit 1
  fi
}

if [ ! -f "${RELEASE_IMAGE}" ]; then
  echo "ERROR: Release image does not exist: ${RELEASE_IMAGE}" >&2
  exit 1
fi

FDISK="$(find_tool fdisk)"
BLKID="$(find_tool blkid)"
CMP="$(find_tool cmp)"
MCOPY="$(find_tool mcopy)"
MDEL="$(find_tool mdel)"
MDIR="$(find_tool mdir)"
SGDISK="$(find_tool sgdisk)"
SSH="$(find_tool ssh)"
SSH_KEYGEN="$(find_tool ssh-keygen)"

if [ ! -f "${ROOTFS_TAR}" ]; then
  echo "ERROR: Root filesystem artifact does not exist: ${ROOTFS_TAR}" >&2
  exit 1
fi
"${PROJECT_ROOT}/scripts/verify-systemd-graph" "${ROOTFS_TAR}"
"${PROJECT_ROOT}/scripts/verify-persistent-logging" "${ROOTFS_TAR}"
"${PROJECT_ROOT}/scripts/verify-config" "${ROOTFS_TAR}"
"${PROJECT_ROOT}/scripts/verify-fah-manifest" "${ROOTFS_TAR}"
mkdir -p "${TEST_DIR}"
ROOTFS_MANIFEST="${TEST_DIR}/rootfs-manifest.txt"
tar -tf "${ROOTFS_TAR}" >"${ROOTFS_MANIFEST}"
for guest_command in \
  cat cp cut fallocate find findmnt foldingosctl grep id journalctl logger \
  networkctl printf readlink rm resolvectl sh sleep ssh-keygen sshd sudo sync \
  systemctl systemd-cat tee timedatectl
do
  if ! grep -Eq \
    "^\./(bin|sbin|usr/bin|usr/sbin)/${guest_command}$" \
    "${ROOTFS_MANIFEST}"
  then
    echo "ERROR: Guest acceptance command is absent from the image: ${guest_command}" >&2
    exit 1
  fi
done
BUILT_FOLDINGOSCTL="${TEST_DIR}/foldingosctl-under-test"
tar -xOf "${ROOTFS_TAR}" ./usr/bin/foldingosctl >"${BUILT_FOLDINGOSCTL}"
if ! grep -aFq "Force-checked %s before data expansion." "${BUILT_FOLDINGOSCTL}"; then
  echo "ERROR: Release artifacts contain a stale foldingosctl binary." >&2
  echo "Rebuild FoldingOS before running QEMU tests." >&2
  exit 1
fi
if ! grep -aFq ".ssh_host_ed25519_key.tmp-" "${BUILT_FOLDINGOSCTL}"; then
  echo "ERROR: Release artifacts contain stale SSH-provisioning behavior." >&2
  echo "Rebuild FoldingOS before running QEMU tests." >&2
  exit 1
fi

echo "Verifying FoldingOS release image"
echo "Image: ${RELEASE_IMAGE}"

actual_size="$(stat -c '%s' "${RELEASE_IMAGE}")"
if [ "${actual_size}" -ne "${EXPECTED_IMAGE_SIZE}" ]; then
  echo "ERROR: Expected a 4 GiB image, found ${actual_size} bytes." >&2
  exit 1
fi

partition_table="$("${FDISK}" -l \
  -o Device,Start,End,Sectors,Size,Type-UUID,UUID,Name \
  "${RELEASE_IMAGE}")"

assert_contains "${partition_table}" \
  "Disk identifier: 464F4C44-494E-474F-5344-49534B000001" \
  "Unexpected disk GUID."
assert_contains "${partition_table}" \
  "2048 1050623 1048576  512M" \
  "Unexpected EFI partition geometry."
assert_contains "${partition_table}" \
  "C12A7328-F81F-11D2-BA4B-00A0C93EC93B 464F4C44-494E-474F-5345-464900000001 FOLDINGOS_EFI" \
  "Unexpected EFI partition."
assert_contains "${partition_table}" \
  "1050624 5244927 4194304    2G" \
  "Unexpected root partition geometry."
assert_contains "${partition_table}" \
  "4F68BCE3-E8CD-4DB1-96E7-FBCAF984B709 464F4C44-494E-474F-5352-4F4F54000001 FOLDINGOS_ROOT" \
  "Unexpected root partition."
assert_contains "${partition_table}" \
  "5244928 8386559 3141632  1.5G" \
  "Unexpected data partition geometry."
assert_contains "${partition_table}" \
  "0FC63DAF-8483-4772-8E79-3D69D8477DE4 464F4C44-494E-474F-5344-415441000001 FOLDINGOS_DATA" \
  "Unexpected data partition."

verify_filesystem "${RELEASE_IMAGE}" 1048576 536870912 \
  FOLDING_EFI 464F-5345 vfat
verify_filesystem "${RELEASE_IMAGE}" 537919488 2147483648 \
  FOLDINGOS_ROOT 464f4c44-494e-474f-5352-4f4f54000001 ext4
verify_filesystem "${RELEASE_IMAGE}" 2685403136 1608515584 \
  FOLDINGOS_DATA 464f4c44-494e-474f-5344-415441000001 ext4

efi_files="$("${MDIR}" -b -i "${RELEASE_IMAGE}@@1048576" \
  ::/EFI/BOOT/BOOTX64.EFI \
  ::/boot/grub/grub.cfg)"
efi_foldingos_directory="$("${MDIR}" -b -i "${RELEASE_IMAGE}@@1048576" \
  ::/foldingos)"
assert_contains "${efi_files}" "BOOTX64.EFI" "EFI fallback bootloader is absent."
assert_contains "${efi_files}" "grub.cfg" "GRUB configuration is absent from EFI."
assert_contains "${efi_foldingos_directory}" \
  "::/foldingos/provision/" \
  "EFI provisioning directory is absent."

echo "Image structure verified."

QEMU="$(find_tool qemu-system-x86_64)"
OVMF_CODE="$(find_ovmf_file OVMF_CODE_4M.fd)"
OVMF_VARS="$(find_ovmf_file OVMF_VARS_4M.fd)"

rm -f \
  "${SSH_KEY}" "${SSH_KEY}.pub" \
  "${SSH_REPLACEMENT_KEY}" "${SSH_REPLACEMENT_KEY}.pub" \
  "${SSH_REPLACEMENT_KEY_SECOND}" "${SSH_REPLACEMENT_KEY_SECOND}.pub" \
  "${SSH_REPLACEMENT_KEYS}" "${INVALID_PROVISION_COPY}"
"${SSH_KEYGEN}" -q -t ed25519 -N "" -f "${SSH_KEY}"
"${SSH_KEYGEN}" -q -t ed25519 -N "" -f "${SSH_REPLACEMENT_KEY}"
"${SSH_KEYGEN}" -q -t ed25519 -N "" -f "${SSH_REPLACEMENT_KEY_SECOND}"
cat "${SSH_REPLACEMENT_KEY}.pub" "${SSH_REPLACEMENT_KEY_SECOND}.pub" >"${SSH_REPLACEMENT_KEYS}"
cp --reflink=auto --sparse=always "${RELEASE_IMAGE}" "${EXACT_IMAGE}"
boot_image "an exact-size image without provisioned SSH keys" "${EXACT_IMAGE}" "${EXACT_SERIAL_LOG}" disabled
assert_expansion_service_succeeded "${EXACT_SERIAL_LOG}"
exact_partition_table="$("${FDISK}" -l \
  -o Device,Start,End,Sectors,Size,Type-UUID,UUID,Name \
  "${EXACT_IMAGE}")"
assert_contains "${exact_partition_table}" \
  "5244928 8386559" \
  "Exact-size disk expansion was not a no-op."

cp --reflink=auto --sparse=always "${RELEASE_IMAGE}" "${LARGER_IMAGE}"
truncate -s "${LARGER_IMAGE_SIZE}" "${LARGER_IMAGE}"
boot_image "a larger image" "${LARGER_IMAGE}" "${LARGER_SERIAL_LOG}"
assert_expansion_service_succeeded "${LARGER_SERIAL_LOG}"

larger_partition_table="$("${FDISK}" -l \
  -o Device,Start,End,Sectors,Size,Type-UUID,UUID,Name \
  "${LARGER_IMAGE}")"
assert_contains "${larger_partition_table}" \
  "5244928 ${LARGER_DATA_END}" \
  "Expanded data partition does not occupy the expected aligned capacity."
assert_contains "${larger_partition_table}" \
  "464F4C44-494E-474F-5344-415441000001 FOLDINGOS_DATA" \
  "Expanded data partition identity changed."

partition_table_before_repeat="${larger_partition_table}"
boot_image "the already-expanded larger image" "${LARGER_IMAGE}" "${REPEAT_SERIAL_LOG}"
assert_expansion_service_succeeded "${REPEAT_SERIAL_LOG}"
partition_table_after_repeat="$("${FDISK}" -l \
  -o Device,Start,End,Sectors,Size,Type-UUID,UUID,Name \
  "${LARGER_IMAGE}")"
if [ "${partition_table_before_repeat}" != "${partition_table_after_repeat}" ]; then
  echo "ERROR: Repeated expansion changed the partition table." >&2
  exit 1
fi

cp --reflink=auto --sparse=always "${RELEASE_IMAGE}" "${PROVISION_IMAGE}"
"${MCOPY}" -o -i "${PROVISION_IMAGE}@@1048576" \
  "${SSH_KEY}.pub" ::/foldingos/provision/authorized_keys
PERSISTENCE_MODE=create
boot_image "an image with provisioned SSH access" \
  "${PROVISION_IMAGE}" "${PROVISION_SERIAL_LOG}" enabled
assert_expansion_service_succeeded "${PROVISION_SERIAL_LOG}"

cp --reflink=auto --sparse=always "${PROVISION_IMAGE}" "${JOURNAL_FAILURE_IMAGE}"
PERSISTENCE_MODE=journal-break
boot_image "a disposable image before persistent-journal failure" \
  "${JOURNAL_FAILURE_IMAGE}" "${JOURNAL_BREAK_SERIAL_LOG}" enabled
PERSISTENCE_MODE=journal-failure
boot_image "an image with unavailable persistent-journal storage" \
  "${JOURNAL_FAILURE_IMAGE}" "${JOURNAL_FAILURE_SERIAL_LOG}" enabled

cp --reflink=auto --sparse=always "${PROVISION_IMAGE}" "${JOURNAL_PRESSURE_IMAGE}"
PERSISTENCE_MODE=journal-pressure
boot_image "an image under persistent-journal storage pressure" \
  "${JOURNAL_PRESSURE_IMAGE}" "${JOURNAL_PRESSURE_SERIAL_LOG}" enabled

cp --reflink=auto --sparse=always "${PROVISION_IMAGE}" "${CONFIG_IMAGE}"
PERSISTENCE_MODE=config
boot_image "a disposable provisioned image for configuration failure tests" \
  "${CONFIG_IMAGE}" "${CONFIG_SERIAL_LOG}" enabled

truncate -s "${LARGER_IMAGE_SIZE}" "${PROVISION_IMAGE}"
PERSISTENCE_MODE=check
boot_image "the provisioned image on a larger disk" \
  "${PROVISION_IMAGE}" "${PRESERVATION_SERIAL_LOG}" enabled
assert_expansion_service_succeeded "${PRESERVATION_SERIAL_LOG}"

"${MCOPY}" -o -i "${PROVISION_IMAGE}@@1048576" \
  "${SSH_KEY}" ::/foldingos/provision/authorized_keys
boot_image "the provisioned image with invalid private-key provisioning input" \
  "${PROVISION_IMAGE}" "${INVALID_PROVISION_SERIAL_LOG}" disabled
if ! grep -Eq 'Failed to start .*Provision FoldingOS SSH access' "${INVALID_PROVISION_SERIAL_LOG}"; then
  echo "ERROR: Invalid private-key provisioning input was not rejected." >&2
  exit 1
fi
"${MCOPY}" -o -i "${PROVISION_IMAGE}@@1048576" \
  ::/foldingos/provision/authorized_keys "${INVALID_PROVISION_COPY}"
if ! "${CMP}" -s "${SSH_KEY}" "${INVALID_PROVISION_COPY}"; then
  echo "ERROR: Rejected private-key provisioning input was modified or removed." >&2
  exit 1
fi
"${MDEL}" -i "${PROVISION_IMAGE}@@1048576" ::/foldingos/provision/authorized_keys
boot_image "the provisioned image after removing invalid provisioning input" \
  "${PROVISION_IMAGE}" "${RECOVERY_SERIAL_LOG}" enabled

"${MCOPY}" -o -i "${PROVISION_IMAGE}@@1048576" \
  "${SSH_REPLACEMENT_KEYS}" ::/foldingos/provision/authorized_keys
SSH_IDENTITY="${SSH_REPLACEMENT_KEY}"
PERSISTENCE_MODE=replacement
boot_image "the provisioned image with a complete replacement SSH key set" \
  "${PROVISION_IMAGE}" "${REPLACEMENT_SERIAL_LOG}" enabled
PERSISTENCE_MODE=none

cp --reflink=auto --sparse=always "${RELEASE_IMAGE}" "${INVALID_IMAGE}"
"${SGDISK}" --change-name=3:UNEXPECTED_DATA "${INVALID_IMAGE}" >/dev/null
invalid_table_before="$("${FDISK}" -l \
  -o Device,Start,End,Sectors,Size,Type-UUID,UUID,Name \
  "${INVALID_IMAGE}")"
boot_image "an image with an invalid partition layout" \
  "${INVALID_IMAGE}" "${INVALID_SERIAL_LOG}"
if ! grep -Eq 'Failed to start .*Expand FoldingOS persistent data partition' "${INVALID_SERIAL_LOG}"; then
  echo "ERROR: Invalid partition layout did not fail expansion safely." >&2
  exit 1
fi
invalid_table_after="$("${FDISK}" -l \
  -o Device,Start,End,Sectors,Size,Type-UUID,UUID,Name \
  "${INVALID_IMAGE}")"
if [ "${invalid_table_before}" != "${invalid_table_after}" ]; then
  echo "ERROR: Invalid-layout expansion changed the partition table." >&2
  exit 1
fi

echo "QEMU/OVMF boot, storage expansion, node identity, configuration management, persistent logging, networking, and secure SSH provisioning verified."
echo "Serial logs: ${EXACT_SERIAL_LOG}, ${LARGER_SERIAL_LOG}, ${REPEAT_SERIAL_LOG}, ${PROVISION_SERIAL_LOG}, ${JOURNAL_BREAK_SERIAL_LOG}, ${JOURNAL_FAILURE_SERIAL_LOG}, ${JOURNAL_PRESSURE_SERIAL_LOG}, ${CONFIG_SERIAL_LOG}, ${PRESERVATION_SERIAL_LOG}, ${INVALID_PROVISION_SERIAL_LOG}, ${RECOVERY_SERIAL_LOG}, ${REPLACEMENT_SERIAL_LOG}, ${INVALID_SERIAL_LOG}"
