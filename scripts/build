#!/usr/bin/env bash
set -euo pipefail

PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

BUILDROOT_VERSION="2026.02.2"
WORK_DIR="${PROJECT_ROOT}/build/work"
BUILDROOT_DIR="${WORK_DIR}/buildroot-${BUILDROOT_VERSION}"
DEFCONFIG="${PROJECT_ROOT}/configs/foldingos_x86_64_defconfig"
FOLDINGOSCTL_PACKAGE="${PROJECT_ROOT}/packages/foldingosctl"
FOLDINGOSCTL_RUST_PACKAGE="${PROJECT_ROOT}/packages/foldingosctl-rust"
BUILDROOT_ASSETS=(
  "../../../overlay"
  "../../../board/foldingos/x86_64/post-build.sh"
  "../../../board/foldingos/x86_64/post-image.sh"
  "../../../board/foldingos/x86_64/users.txt"
  "../../../configs/linux-x86_64.config"
  "../../../packages/foldingosctl/Config.in"
  "../../../packages/foldingosctl/foldingosctl.mk"
  "../../../packages/foldingosctl-rust/Config.in"
  "../../../packages/foldingosctl-rust/foldingosctl-rust.mk"
  "../../../packages/foldingosctl/rust/Cargo.toml"
  "../../../packages/foldingosctl/rust/Cargo.lock"
  "../../../packages/foldingosctl/rust/.cargo/config.toml"
  "../../../packages/foldingosctl/rust/VENDOR/serde/Cargo.toml"
  "../../../packages/foldingosctl/rust/src/main.rs"
  "../../../packages/foldingosctl/src/go.mod"
  "../../../packages/foldingosctl/src/go.sum"
  "../../../packages/foldingosctl/src/config.go"
  "../../../packages/foldingosctl/src/files.go"
  "../../../packages/foldingosctl/src/identity.go"
  "../../../packages/foldingosctl/src/boot.go"
  "../../../packages/foldingosctl/src/boot_display.go"
  "../../../packages/foldingosctl/src/fah.go"
  "../../../packages/foldingosctl/src/foldops.go"
  "../../../packages/foldingosctl/src/foldops_acquire.go"
  "../../../packages/foldingosctl/src/foldops_acquire_state.go"
  "../../../packages/foldingosctl/src/foldops_extract.go"
  "../../../packages/foldingosctl/src/foldops_activate.go"
  "../../../packages/foldingosctl/src/foldops_provision.go"
  "../../../packages/foldingosctl/src/foldops_tls.go"
  "../../../packages/foldingosctl/src/foldops_serve_https.go"
  "../../../packages/foldingosctl/src/tools.go"
  "../../../packages/foldingosctl/src/tools_acquire.go"
  "../../../packages/foldingosctl/src/tools_acquire_state.go"
  "../../../packages/foldingosctl/src/tools_replace.go"
  "../../../packages/foldingosctl/src/registry_foldops.go"
  "../../../packages/foldingosctl/src/registry_tools.go"
  "../../../packages/foldingosctl/src/provision_assignments.go"
  "../../../packages/foldingosctl/src/automation_json.go"
  "../../../packages/foldingosctl/src/automation_auth.go"
  "../../../packages/foldingosctl/src/inspect.go"
  "../../../packages/foldingosctl/src/inspect_system.go"
  "../../../packages/foldingosctl/src/inspect_fah.go"
  "../../../packages/foldingosctl/src/inspect_update.go"
  "../../../packages/foldingosctl/src/inspect_runtime.go"
  "../../../packages/foldingosctl/src/fah_acquire.go"
  "../../../packages/foldingosctl/src/fah_acquire_state.go"
  "../../../packages/foldingosctl/src/fah_extract.go"
  "../../../packages/foldingosctl/src/fah_verify_install.go"
  "../../../packages/foldingosctl/src/fah_activate.go"
  "../../../packages/foldingosctl/src/fah_prepare.go"
  "../../../packages/foldingosctl/src/fah_run.go"
  "../../../packages/foldingosctl/src/main.go"
  "../../../packages/foldingosctl/src/main_test.go"
  "../../../packages/foldingosctl/src/provision.go"
  "../../../packages/foldingosctl/src/installation_role.go"
  "../../../packages/foldingosctl/src/installation_role_test.go"
  "../../../packages/foldingosctl/src/registry.go"
  "../../../packages/foldingosctl/src/registry_import.go"
  "../../../packages/foldingosctl/src/registry_poll.go"
  "../../../packages/foldingosctl/src/registry_test.go"
  "../../../packages/foldingosctl/src/provision_enrollment.go"
  "../../../packages/foldingosctl/src/provision_serve.go"
  "../../../packages/foldingosctl/src/provision_enroll.go"
  "../../../packages/foldingosctl/src/provision_enroll_test.go"
  "../../../packages/foldingosctl/src/provision_assign.go"
  "../../../packages/foldingosctl/src/provision_enrollment_test.go"
  "../../../packages/foldingosctl/src/provision_targets.go"
  "../../../packages/foldingosctl/src/provision_authorize.go"
  "../../../packages/foldingosctl/src/provision_stream_handlers.go"
  "../../../packages/foldingosctl/src/provision_install.go"
  "../../../packages/foldingosctl/src/provision_install_test.go"
  "../../../packages/foldingosctl/src/provision_stream_test.go"
  "../../../packages/foldingosctl/src/provision_boot.go"
  "../../../packages/foldingosctl/src/provision_boot_handlers.go"
  "../../../packages/foldingosctl/src/provision_boot_test.go"
  "../../../packages/foldingosctl/src/provision_update.go"
  "../../../packages/foldingosctl/src/provision_update_handlers.go"
  "../../../packages/foldingosctl/src/provision_update_test.go"
  "../../../board/foldingos/x86_64/mk-install-initramfs.sh"
  "../../../board/foldingos/x86_64/install-initramfs/init"
)

echo "FoldingOS build"
echo "Project root: ${PROJECT_ROOT}"
echo "Buildroot: ${BUILDROOT_VERSION}"

if [ "$(id -u)" -eq 0 ]; then
  echo "ERROR: Do not run this build as root."
  exit 1
fi

if [ ! -f "${DEFCONFIG}" ]; then
  echo "ERROR: Missing defconfig:"
  echo "${DEFCONFIG}"
  exit 1
fi

"${PROJECT_ROOT}/scripts/verify-fah-manifest"
"${PROJECT_ROOT}/scripts/verify-foldops-manifest"

"${PROJECT_ROOT}/scripts/fetch-sources"

cd "${BUILDROOT_DIR}"

echo "Checking Buildroot project paths"
for asset in "${BUILDROOT_ASSETS[@]}"; do
  if [ ! -e "${asset}" ]; then
    echo "ERROR: Buildroot project path does not resolve:"
    echo "${asset}"
    exit 1
  fi
done

echo "Staging repository-local Buildroot packages"
rm -rf "${BUILDROOT_DIR}/package/foldingosctl"
cp -a "${FOLDINGOSCTL_PACKAGE}" "${BUILDROOT_DIR}/package/foldingosctl"
if ! grep -Fq 'source "package/foldingosctl/Config.in"' "${BUILDROOT_DIR}/package/Config.in"; then
  sed -i \
    '/menu "Target packages"/a\	source "package/foldingosctl/Config.in"' \
    "${BUILDROOT_DIR}/package/Config.in"
fi
rm -rf "${BUILDROOT_DIR}/package/foldingosctl-rust"
cp -a "${FOLDINGOSCTL_RUST_PACKAGE}" "${BUILDROOT_DIR}/package/foldingosctl-rust"
if ! grep -Fq 'source "package/foldingosctl-rust/Config.in"' "${BUILDROOT_DIR}/package/Config.in"; then
  sed -i \
    '/menu "Target packages"/a\	source "package/foldingosctl-rust/Config.in"' \
    "${BUILDROOT_DIR}/package/Config.in"
fi

echo "Applying FoldingOS defconfig"
make \
  O="${PROJECT_ROOT}/build/output" \
  BR2_DEFCONFIG="${DEFCONFIG}" \
  defconfig

# Buildroot local-package source changes do not invalidate an already-rsynced
# package automatically. Rebuild this small repository-owned package every time
# so an incremental image can never silently contain stale foldingosctl code.
echo "Invalidating repository-local foldingosctl build"
make \
  O="${PROJECT_ROOT}/build/output" \
  foldingosctl-dirclean
make \
  O="${PROJECT_ROOT}/build/output" \
  foldingosctl-rust-dirclean

echo "Building FoldingOS"
make O="${PROJECT_ROOT}/build/output"

FOLDINGOSCTL_BINARY="${PROJECT_ROOT}/build/output/target/usr/bin/foldingosctl"
if [ ! -x "${FOLDINGOSCTL_BINARY}" ]; then
  echo "ERROR: Built foldingosctl binary is missing:"
  echo "${FOLDINGOSCTL_BINARY}"
  exit 1
fi
if ! grep -aFq "Force-checked %s before data expansion." "${FOLDINGOSCTL_BINARY}"; then
  echo "ERROR: Built foldingosctl binary is stale."
  echo "Expected current storage-check behavior was not found."
  exit 1
fi
if ! grep -aFq ".ssh_host_ed25519_key.tmp-" "${FOLDINGOSCTL_BINARY}"; then
  echo "ERROR: Built foldingosctl binary is stale."
  echo "Expected current SSH-provisioning behavior was not found."
  exit 1
fi

FOLDINGOSCTL_RUST_BINARY="${PROJECT_ROOT}/build/output/target/usr/bin/foldingosctl-rust"
if [ ! -x "${FOLDINGOSCTL_RUST_BINARY}" ]; then
  echo "ERROR: Built foldingosctl-rust binary is missing:"
  echo "${FOLDINGOSCTL_RUST_BINARY}"
  exit 1
fi
if ! grep -aFq "FOLDINGOSCTL_RUST_PHASE_1" "${FOLDINGOSCTL_RUST_BINARY}"; then
  echo "ERROR: Built foldingosctl-rust binary is stale."
  echo "Expected Rust migration phase 1 marker was not found."
  exit 1
fi

echo "Generating FoldingOS build artifacts"
"${PROJECT_ROOT}/tools/release/generate-build-artifacts" \
  "${PROJECT_ROOT}" \
  "${PROJECT_ROOT}/build/output/images"

echo
echo "Build complete."
echo "Output directory:"
echo "${PROJECT_ROOT}/build/output/images"
