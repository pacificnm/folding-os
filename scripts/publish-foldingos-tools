#!/usr/bin/env bash
# Upload build/output/foldingos-tools/<version>/ to packages.folding-os.com (R2-backed).
set -euo pipefail

PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=lib/packages-channel.sh
source "${PROJECT_ROOT}/scripts/lib/packages-channel.sh"

usage() {
  cat <<EOF
Usage: $(basename "$0") [options] <tools_version>

Upload foldingosctl tools release from:
  build/output/foldingos-tools/<tools_version>/

Options:
  --dry-run       List planned uploads without writing objects
  --skip-index    Upload artifacts only; do not refresh index.json
  -h, --help      Show this help

Environment:
  R2_REMOTE                       rclone remote name (default: r2)
  FOLDOPS_R2_BUCKET               destination bucket (default: foldops-packages)
  TOOLS_R2_PREFIX                 object prefix inside bucket (default: foldingos-tools)
  PACKAGES_PUBLIC_BASE            public HTTPS base (default: https://packages.folding-os.com)
  PACKAGES_MINIMUM_FOLDINGOS_VERSION  minimum compatible FoldingOS version (default: 0.1.0)

Requires rclone configured at ~/.config/rclone/rclone.conf.
EOF
}

DRY_RUN=0
SKIP_INDEX=0

while [ "$#" -gt 0 ]; do
  case "$1" in
    --dry-run)
      DRY_RUN=1
      shift
      ;;
    --skip-index)
      SKIP_INDEX=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --*)
      echo "ERROR: unknown option: $1" >&2
      usage >&2
      exit 1
      ;;
    *)
      break
      ;;
  esac
done

if [ "$#" -lt 1 ]; then
  usage >&2
  exit 1
fi

TOOLS_VERSION="$1"
SOURCE_DIR="${PROJECT_ROOT}/build/output/foldingos-tools/${TOOLS_VERSION}"
packages_channel_defaults
DEST="${R2_REMOTE}:${FOLDOPS_R2_BUCKET}/${TOOLS_R2_PREFIX}/${TOOLS_VERSION}/"

if [ ! -d "${SOURCE_DIR}" ]; then
  echo "ERROR: source directory not found: ${SOURCE_DIR}" >&2
  echo "Run ./scripts/build-foldingosctl-release --version ${TOOLS_VERSION} --sync-overlay first." >&2
  exit 1
fi

required=(
  "foldingosctl-x86_64"
  "SHA256SUMS"
)
for file in "${required[@]}"; do
  if [ ! -f "${SOURCE_DIR}/${file}" ]; then
    echo "ERROR: missing required artifact: ${SOURCE_DIR}/${file}" >&2
    exit 1
  fi
done

if [ "${DRY_RUN}" -eq 0 ]; then
  packages_require_rclone
fi

echo "Publishing foldingosctl tools release ${TOOLS_VERSION}"
echo "  source: ${SOURCE_DIR}"
echo "  dest:   ${DEST}"

if [ "${DRY_RUN}" -eq 1 ]; then
  echo "Dry run — would upload:"
  find "${SOURCE_DIR}" -maxdepth 1 -type f -printf '  %f\n' | sort
else
  rclone copy "${SOURCE_DIR}/" "${DEST}" --checksum --progress
fi

if [ "${SKIP_INDEX}" -eq 0 ]; then
  packages_refresh_tools_index "${TOOLS_VERSION}"
fi

echo ""
echo "Published. Public URL base:"
echo "  ${PACKAGES_PUBLIC_BASE}/${TOOLS_R2_PREFIX}/${TOOLS_VERSION}/"
echo "Index:"
echo "  ${PACKAGES_PUBLIC_BASE}/${TOOLS_R2_PREFIX}/index.json"
