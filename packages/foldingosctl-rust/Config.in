config BR2_PACKAGE_FOLDINGOSCTL_RUST
	bool "foldingosctl (Rust migration build)"
	depends on BR2_PACKAGE_FOLDINGOSCTL
	depends on BR2_PACKAGE_HOST_RUSTC_TARGET_ARCH_SUPPORTS
	select BR2_PACKAGE_HOST_RUSTC
	help
	  Build the in-progress Rust foldingosctl binary as
	  /usr/bin/foldingosctl-rust during the Go to Rust migration
	  (ADR-0025 phase 1). The production entry point remains the Go
	  /usr/bin/foldingosctl until migration parity is complete.
