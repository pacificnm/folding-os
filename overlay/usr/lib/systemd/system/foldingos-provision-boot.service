[Unit]
Description=FoldingOS supervisor network boot assistance
Requires=foldingos-installation-role.service foldingos-provision.service
After=foldingos-installation-role.service foldingos-provision.service network-online.target
Wants=network-online.target
ConditionPathExists=/data/config/installation-role

[Service]
Type=simple
ExecCondition=/bin/sh -c 'grep -qx supervisor /data/config/installation-role'
ExecStart=/usr/bin/foldingosctl provision boot
Restart=on-failure
RestartSec=10s

[Install]
WantedBy=multi-user.target
