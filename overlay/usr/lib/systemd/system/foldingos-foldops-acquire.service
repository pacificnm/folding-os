[Unit]
Description=Acquire verified FoldOps packages
After=network-online.target systemd-time-wait-sync.service data.mount foldingos-installation-role.service
Wants=network-online.target
ConditionPathExists=/data/config/installation-role

[Service]
Type=oneshot
ExecStart=/usr/bin/foldingosctl foldops acquire
RemainAfterExit=no
