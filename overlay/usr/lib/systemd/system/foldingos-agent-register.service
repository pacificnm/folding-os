[Unit]
Description=Register FoldingOS agent with supervisor
Requires=foldingos-installation-role.service
After=foldingos-installation-role.service network-online.target
Wants=network-online.target
Before=foldingos-agent-version-check.service
ConditionPathExists=/data/config/installation-role

[Service]
Type=oneshot
ExecCondition=/bin/sh -c 'grep -qx agent /data/config/installation-role'
ExecStart=/usr/bin/foldingosctl provision enroll
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
