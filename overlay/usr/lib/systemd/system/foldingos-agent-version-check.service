[Unit]
Description=Check desired FoldingOS image version with supervisor
Requires=foldingos-agent-register.service
After=foldingos-agent-register.service network-online.target
Wants=network-online.target
ConditionPathExists=/data/config/installation-role

[Service]
Type=oneshot
ExecCondition=/bin/sh -c 'grep -qx agent /data/config/installation-role'
ExecStart=/usr/bin/foldingosctl provision check-version
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
