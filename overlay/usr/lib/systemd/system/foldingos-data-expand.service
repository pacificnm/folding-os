[Unit]
Description=Expand FoldingOS persistent data partition
DefaultDependencies=no
Requires=boot-efi.mount
After=boot-efi.mount
Before=data.mount

[Service]
Type=oneshot
ExecStart=/usr/bin/foldingosctl storage expand-data
StandardOutput=journal+console
StandardError=journal+console
RemainAfterExit=yes

[Install]
WantedBy=local-fs.target
