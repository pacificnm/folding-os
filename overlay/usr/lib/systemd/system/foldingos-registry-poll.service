[Unit]
Description=Poll upstream for approved FoldingOS release images
After=network-online.target foldingos-registry-bootstrap.service
Wants=network-online.target
ConditionPathExists=/data/config/installation-role

[Service]
Type=oneshot
ExecCondition=/bin/sh -c 'grep -qx supervisor /data/config/installation-role'
ExecStart=/usr/bin/foldingosctl registry poll
