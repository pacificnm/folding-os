[Unit]
Description=Import the running supervisor image into the local registry
Requires=foldingos-installation-role.service
After=foldingos-installation-role.service
ConditionPathExists=/data/config/installation-role

[Service]
Type=oneshot
ExecCondition=/bin/sh -c 'grep -qx supervisor /data/config/installation-role'
ExecStart=/usr/bin/foldingosctl registry import-bootstrap
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
